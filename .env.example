# =====================================================
# WHALE PLATFORM / MONTREE — Environment Variables
# =====================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =====================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth Secrets ---
ADMIN_SECRET=                         # REQUIRED — JWT signing for Whale Class admin (min 32 chars)
ADMIN_USERNAME=                       # Whale Class admin username
ADMIN_PASSWORD=                       # Whale Class admin password
SUPER_ADMIN_PASSWORD=                 # REQUIRED — Montree super-admin login
TEACHER_ADMIN_PASSWORD=               # REQUIRED — Whale Class teacher login

# --- Story System ---
STORY_JWT_SECRET=                     # REQUIRED — Story JWT signing (64-char hex recommended)

# --- AI / External APIs ---
ANTHROPIC_API_KEY=                    # Anthropic Claude API (for Guru advisor)
OPENAI_API_KEY=                       # OpenAI DALL-E (image generation)
NEXT_PUBLIC_YOUTUBE_API_KEY=          # YouTube Data API

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=            # Supabase service role key (server-side only)
DATABASE_URL=                         # PostgreSQL connection string

# --- Encryption ---
MESSAGE_ENCRYPTION_KEY=               # REQUIRED — Exactly 32 characters for AES-256 (no quotes!)
VAULT_PASSWORD=                       # REQUIRED — Vault file encryption password
VAULT_PASSWORD_HASH=                  # REQUIRED — bcrypt hash for vault unlock verification

# --- Email ---
RESEND_API_KEY=                       # Resend.com API key
RESEND_FROM_EMAIL=Montree <onboarding@resend.dev>

# --- Optional Auth Overrides (Phase 9) ---
MONTREE_JWT_SECRET=                   # Optional — JWT signing for Montree teacher auth (falls back to ADMIN_SECRET)
STORY_ADMIN_JWT_SECRET=               # Optional — Story admin JWT signing (falls back to STORY_JWT_SECRET)
AUTH_SECRET=                          # Optional — Alternative to ADMIN_SECRET for multi-auth (falls back to ADMIN_SECRET)
SUPER_ADMIN_ENCRYPTION_KEY=           # Optional — Super-admin AES-256 encryption (falls back to MESSAGE_ENCRYPTION_KEY)

# --- Stripe (if billing enabled) ---
# Test mode keys start with pk_test_ and sk_test_
# Live mode keys start with pk_live_ and sk_live_
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRICE_GURU_MONTHLY=price_REPLACE_WITH_GURU_MONTHLY_PRICE_ID
STRIPE_PRICE_BASIC=price_REPLACE_WITH_BASIC_PLAN_PRICE_ID
STRIPE_PRICE_STANDARD=price_REPLACE_WITH_STANDARD_PLAN_PRICE_ID
STRIPE_PRICE_PREMIUM=price_REPLACE_WITH_PREMIUM_PLAN_PRICE_ID
STRIPE_SCHOOL_PRICE_ID=price_REPLACE_WITH_SCHOOL_MONTHLY_PRICE_ID
STRIPE_DISTRICT_PRICE_ID=price_REPLACE_WITH_DISTRICT_MONTHLY_PRICE_ID
