# =====================================================
# WHALE PLATFORM / MONTREE — Environment Variables
# =====================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =====================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth Secrets ---
ADMIN_SECRET=                         # REQUIRED — JWT signing for Whale Class admin (min 32 chars)
ADMIN_USERNAME=                       # Whale Class admin username
ADMIN_PASSWORD=                       # Whale Class admin password
SUPER_ADMIN_PASSWORD=                 # REQUIRED — Montree super-admin login
TEACHER_ADMIN_PASSWORD=               # REQUIRED — Whale Class teacher login

# --- Story System ---
STORY_JWT_SECRET=                     # REQUIRED — Story JWT signing (64-char hex recommended)

# --- Personal Platform (Diary + Planner + Projects + AI Coach @ /story/admin) ---
STORY_DIARY_KEY=                      # REQUIRED for diary/projects/coach — 32-byte hex (64 chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))". Diary writes FAIL CLOSED without it.
STORY_MESSAGES_PHRASE=                # REQUIRED to reveal the hidden Messages — the secret phrase typed after a 2s long-press on the diary logo. Without it the comms dashboard stays hidden (fail-closed).

# --- AI / External APIs ---
ANTHROPIC_API_KEY=                    # Anthropic Claude API (for Guru advisor)
OPENAI_API_KEY=                       # OpenAI DALL-E (image generation)
NEXT_PUBLIC_YOUTUBE_API_KEY=          # YouTube Data API

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=            # Supabase service role key (server-side only)
DATABASE_URL=                         # PostgreSQL connection string

# --- Encryption ---
MESSAGE_ENCRYPTION_KEY=               # REQUIRED — Exactly 32 characters for AES-256 (no quotes!)
VAULT_PASSWORD=                       # REQUIRED — Vault file encryption password
VAULT_PASSWORD_HASH=                  # REQUIRED — bcrypt hash for vault unlock verification

# --- Email ---
RESEND_API_KEY=                       # Resend.com API key
RESEND_FROM_EMAIL=Montree <onboarding@resend.dev>

# --- Optional Auth Overrides (Phase 9) ---
MONTREE_JWT_SECRET=                   # ⚠️ SET THIS IN RAILWAY (= current ADMIN_SECRET value) — JWT signing for Montree teacher auth; unset = falls back to ADMIN_SECRET, and rotating ADMIN_SECRET then logs out EVERY school (Session 140 incident)
SUPER_ADMIN_JWT_SECRET=               # ⚠️ RECOMMENDED — long random key for super-admin session tokens; unset = tokens are signed with SUPER_ADMIN_PASSWORD itself (forgeable if password is weak)
STORY_ADMIN_JWT_SECRET=               # Optional — Story admin JWT signing (falls back to STORY_JWT_SECRET)
AUTH_SECRET=                          # Optional — Alternative to ADMIN_SECRET for multi-auth (falls back to ADMIN_SECRET)
SUPER_ADMIN_ENCRYPTION_KEY=           # Optional — Super-admin AES-256 encryption (falls back to MESSAGE_ENCRYPTION_KEY)

# --- Stripe (if billing enabled) ---
# Test mode keys start with pk_test_ and sk_test_
# Live mode keys start with pk_live_ and sk_live_
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
# Phase 3 — Connect webhook is a SEPARATE endpoint with its own secret.
# Subscribe to event: account.updated  (Connect mode, not Account mode).
# Falls back to STRIPE_WEBHOOK_SECRET if not set, but use the dedicated one in production.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_CONNECT_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
# Where Stripe sends agents after Connect onboarding. Defaults to https://montree.xyz.
NEXT_PUBLIC_APP_URL=https://montree.xyz

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRICE_GURU_MONTHLY=price_REPLACE_WITH_GURU_MONTHLY_PRICE_ID
STRIPE_PRICE_BASIC=price_REPLACE_WITH_BASIC_PLAN_PRICE_ID
STRIPE_PRICE_STANDARD=price_REPLACE_WITH_STANDARD_PLAN_PRICE_ID
STRIPE_PRICE_PREMIUM=price_REPLACE_WITH_PREMIUM_PLAN_PRICE_ID
STRIPE_SCHOOL_PRICE_ID=price_REPLACE_WITH_SCHOOL_MONTHLY_PRICE_ID
STRIPE_DISTRICT_PRICE_ID=price_REPLACE_WITH_DISTRICT_MONTHLY_PRICE_ID

# Phase 4 — School subscription billing ($7/active-student/month).
# When STRIPE_SECRET_KEY + STRIPE_PRICE_PER_STUDENT + STRIPE_WEBHOOK_SECRET
# are all present, /montree/admin/billing flips from "not set up yet" to
# functional. See docs/STRIPE_BILLING_SETUP.md for the full setup.
STRIPE_PRICE_PER_STUDENT=price_REPLACE_WITH_7USD_PER_STUDENT_MONTHLY_PRICE_ID

# Optional: shared secret for the daily headcount sync sweep (cron).
# Set to a random 32-char string. POST /api/montree/billing/sync-quantity
# with header `x-cron-secret: <value>` to trigger the all-schools sweep
# without super-admin auth.
CRON_SECRET=replace_with_random_32_char_string
