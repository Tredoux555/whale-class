<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDisplayName</key>
  <string>Lyf Coach</string>
  <key>CFBundleName</key>
  <string>Lyf Coach</string>
  <key>CFBundleExecutable</key>
  <string>$(EXECUTABLE_NAME)</string>

  <!-- Export compliance: the app uses only STANDARD encryption (TLS + libsodium)
       to protect the user's own data — it is not a cryptography tool. This
       declares it carries no NON-exempt encryption, so no annual export docs are
       needed. Confirm this self-classification before release. -->
  <key>ITSAppUsesNonExemptEncryption</key>
  <false/>
  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleShortVersionString</key>
  <string>$(MARKETING_VERSION)</string>
  <key>CFBundleVersion</key>
  <string>$(CURRENT_PROJECT_VERSION)</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSRequiresIPhoneOS</key>
  <true/>

  <!-- Face ID / Touch ID unlock for the on-device content key. -->
  <key>NSFaceIDUsageDescription</key>
  <string>Lyf Coach uses Face ID to unlock your private, on-device-encrypted journal.</string>

  <!-- App Transport Security: HTTPS only (the API is https://montree.xyz). -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoads</key>
    <false/>
  </dict>

  <!-- SwiftUI App lifecycle — no storyboard. -->
  <key>UILaunchScreen</key>
  <dict/>
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>
  <key>UIApplicationSupportsIndirectInputEvents</key>
  <true/>
</dict>
</plist>
